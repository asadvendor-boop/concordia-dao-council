# Concordia DAO Council
APP_ENV=development
PUBLIC_BASE_URL=http://localhost:8000
GATEWAY_DB_PATH=concordia.db
GATEWAY_SECRET=dev-gateway-secret
APPROVAL_UI_CSRF_SECRET=dev-csrf-secret
CONCORDIA_OPERATOR_TOKEN=dev-operator-token
CONCORDIA_TEST_MODE=1
CONCORDIA_DISABLE_LLM_REASONING=1

# OpenAI-compatible advisory LLM settings. These are optional for mock/local mode.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_TRIAGE_MODEL=gpt-4o-mini
LLM_DIAGNOSIS_MODEL=gpt-4o
LLM_SAFETY_MODEL=gpt-4o
LLM_COMMANDER_MODEL=gpt-4o
LLM_OPERATOR_MODEL=gpt-4o-mini
LLM_SCRIBE_MODEL=gpt-4o-mini

# Agent IDs and keys. Use stable IDs in local demo.
RECORDER_AGENT_ID=recorder-concordia-core
TRIAGE_AGENT_ID=rowan-proposal-sentinel
DIAGNOSIS_AGENT_ID=mercer-treasury-intelligence
SAFETY_REVIEWER_AGENT_ID=verity-risk-legal
COMMANDER_AGENT_ID=alden-protocol-strategy
OPERATOR_AGENT_ID=locke-casper-execution
SCRIBE_AGENT_ID=wells-governance-archivist
HUMAN_APPROVER_IDS=dao-multisig-1

RECORDER_SUBMISSION_KEY=dev-recorder-key
TRIAGE_SUBMISSION_KEY=dev-rowan-key
DIAGNOSIS_SUBMISSION_KEY=dev-mercer-key
SAFETY_REVIEWER_SUBMISSION_KEY=dev-verity-key
COMMANDER_SUBMISSION_KEY=dev-alden-key
OPERATOR_SUBMISSION_KEY=dev-locke-key
SCRIBE_SUBMISSION_KEY=dev-wells-key

# Casper Testnet execution. Use mock locally; switch to real for final proof.
CASPER_EXECUTION_MODE=mock
CASPER_SECRET_KEY_PATH=
# Must include the hash- prefix after Testnet deployment.
CASPER_RECEIPT_CONTRACT_HASH=
CASPER_ENTRY_POINT=store_governance_receipt
CASPER_NODE_ADDRESS=https://node.testnet.cspr.cloud
CASPER_CHAIN_NAME=casper-test
CASPER_PAYMENT_AMOUNT=5000000000
CASPER_EXECUTION_DRIVER=pycspr
CONCORDIA_PYCSPR_DRY_RUN=0
# Run `make casper-preflight` before recording the final Testnet demo.

# CSPR.cloud adapters.
CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_STREAM_URL=wss://streaming.testnet.cspr.cloud
CSPR_NODE_RPC_URL=https://node.testnet.cspr.cloud/rpc
CSPR_CLOUD_ACCESS_TOKEN=
# In CASPER_EXECUTION_MODE=real, CSPR.cloud helpers return not_configured unless this token is set.

# MCP adapters.
CASPER_MCP_URL=
CSPR_TRADE_MCP_URL=
# Set to 1 only for fully offline local demos. When 0, the MCP bridge exposes a live Casper node-status JSON-RPC tool.
CASPER_MCP_OFFLINE_MOCK=0
CASPER_PUBLIC_STATUS_URL=https://testnet.cspr.live

# x402 paid report adapter.
X402_PAYMENT_ADDRESS=
X402_PAYMENT_AMOUNT=1000000
X402_PAYMENT_NETWORK=casper-testnet
