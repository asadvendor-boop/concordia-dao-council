CONCORDIA_HOSTNAME=concordia.47.84.232.193.sslip.io
# Required at release time. Set this to the exact reviewed deployment commit;
# leaving it empty makes Compose refuse the production configuration.
CONCORDIA_DEPLOYMENT_COMMIT=

LLM_BASE_URL=https://your-openai-compatible-endpoint.example/v1
LLM_TRIAGE_MODEL=fast-advisory-model
LLM_DIAGNOSIS_MODEL=deep-advisory-model
LLM_SAFETY_MODEL=deep-advisory-model
LLM_COMMANDER_MODEL=deep-advisory-model
LLM_OPERATOR_MODEL=fast-advisory-model
LLM_SCRIBE_MODEL=fast-advisory-model

CONCORDIA_REQUIRE_LIVE_LLM=1
CONCORDIA_DISABLE_LLM_REASONING=0
CONCORDIA_TEST_MODE=0
CONCORDIA_LIVE_DEMO=0

CASPER_EXECUTION_MODE=real
CASPER_EXECUTION_DRIVER=pycspr
CONCORDIA_PYCSPR_DRY_RUN=0
CASPER_RECEIPT_CONTRACT_HASH=hash-your-64-hex-testnet-contract
CASPER_NODE_ADDRESS=https://node.testnet.casper.network
CSPR_NODE_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test
CASPER_PAYMENT_AMOUNT=5000000000
CASPER_ENTRY_POINT=store_governance_receipt
# Optional until the Odra quorum package is deployed and exercised.
CASPER_QUORUM_PACKAGE_HASH=
CASPER_QUORUM_CONTRACT_VERSION=1

CASPER_MCP_OFFLINE_MOCK=0
CASPER_PUBLIC_STATUS_URL=https://testnet.cspr.live
CSPR_TRADE_MCP_URL=https://mcp.cspr.trade/mcp
CSPR_TRADE_SLIPPAGE_BPS=50
# Optional: Mercer alone receives this Docker secret; never place the token in
# the shared Compose environment.
CSPR_CLOUD_ACCESS_TOKEN_FILE=/opt/apps/concordia/secrets/cspr_cloud_access_token
CONCORDIA_RATE_LIMIT_PER_MINUTE=240
CONCORDIA_RATE_LIMIT_WINDOW_SECONDS=60
