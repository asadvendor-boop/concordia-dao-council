        {
          "$ref": "#/$defs/official_19"
        },
        {
          "$ref": "#/$defs/official_20"
        },
        {
          "$ref": "#/$defs/official_21"
        },
        {
          "$ref": "#/$defs/official_22"
        }
      ],
      "items": false
    },
    "exact_01": {
      "$ref": "#/$defs/registry_check_base",
      "properties": {
        "name": {
          "const": "source_tree_sha256_matches_release_manifest"
        }
      }
    },
    "exact_02": {
      "$ref": "#/$defs/registry_check_base",
      "properties": {
